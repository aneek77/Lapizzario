# ==== COPY THIS FILE TO ".env" AND FILL IN YOUR REAL VALUES ====

# ---- UPI QR payments (money goes straight to your bank, zero fees) ----
# Your restaurant's UPI ID — the one you use to receive money in GPay/PhonePe/
# Paytm Business etc. Examples: lapizzario@okhdfcbank, 9126996094@ybl
# IMPORTANT: staff must verify each UPI payment arrived in your UPI app
# before preparing the order (the dashboard reminds you).
UPI_ID=yourupiid@bank
UPI_NAME=La Pizzario

# ---- Razorpay (for card/netbanking payments) ----
# Get these from https://dashboard.razorpay.com -> Settings -> API Keys
# Use TEST keys first (rzp_test_...), switch to LIVE keys (rzp_live_...) after testing.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email (Gmail is easiest) ----
# 1. Use a Gmail account (e.g. lapizzario.orders@gmail.com)
# 2. Turn on 2-Step Verification in that Google account
# 3. Create an "App Password": https://myaccount.google.com/apppasswords
# 4. Put the 16-character app password below (NOT your normal password)
SMTP_USER=lapizzario.orders@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Where should NEW ORDER notifications go? (can be same as SMTP_USER)
RESTAURANT_EMAIL=lapizzario.orders@gmail.com

# ---- Staff dashboard password (change this!) ----
STAFF_PASSWORD=pizzario123

# ---- Server port ----
PORT=3000
